// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  TEACHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  role          Role      @default(USER)
  hashedPassword      String?
  teacherProfile  Teacher?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Specialty {
  id        String    @id @default(cuid())
  name      String    @unique
  teachers  Teacher[]
  classes   Class[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Teacher {
  id          String      @id @default(cuid())
  userId      String      @unique
  phone       String?
  bio         String?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes     Class[]     @relation("ClassTeachers")
  specialties Specialty[]
  sessions    ClassSession[]
}

model Class {
  id          String         @id @default(cuid())
  name        String         // Tên lớp học
  schedule    String?        // Lịch học (tùy chọn, có thể tự động lấy từ buổi học)
  room        String?        // Phòng học hoặc link online
  teachers    Teacher[]      @relation("ClassTeachers")
  students    StudentClass[]
  specialties Specialty[]
  sessions    ClassSession[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model StudentClass {
  id          String   @id @default(cuid())
  studentCode String?  // Mã học sinh để theo dõi nhiều khóa
  studentName String
  studentAge  Int
  parentName  String
  parentPhone String
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClassSession {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  date        DateTime // Ngày diễn ra buổi học
  startTime   String   // HH:mm (e.g. "08:00")
  endTime     String   // HH:mm (e.g. "10:00")
  room        String?  // Phòng học / Link học trực tuyến
  isMakeup    Boolean  @default(false) // Học bù
  description String?  // Ghi chú (ví dụ: Lý do học bù, nội dung học...)
  status      String   @default("SCHEDULED") // SCHEDULED, CANCELLED, COMPLETED
  attendance  Attendance[]
  artworks    StudentArtwork[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id             String       @id @default(cuid())
  sessionId      String
  session        ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentClassId String
  studentClass   StudentClass @relation(fields: [studentClassId], references: [id], onDelete: Cascade)
  status         String       // PRESENT, ABSENT, LATE
  notes          String?      // Ghi chú chi tiết (ví dụ: nghỉ có phép, đi muộn 15p...)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([sessionId, studentClassId])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String   @default("Chung")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentArtwork {
  id           String        @id @default(cuid())
  studentCode  String        // Mã học sinh để liên kết
  imageUrl     String        // Link tranh vẽ đã tải lên
  title        String?       // Tên tác phẩm
  comment      String?       @db.Text // Nhận xét của giáo viên
  teacherName  String?       // Tên giáo viên nhận xét
  className    String?       // Tên lớp học khi vẽ tranh
  sessionId    String?       // Liên kết với buổi học cụ thể
  session      ClassSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date         DateTime      @default(now()) // Ngày vẽ tranh
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String                        // Họ tên phụ huynh
  phone     String                        // Số điện thoại liên hệ
  email     String?                       // Email (tùy chọn)
  message   String   @db.Text            // Nội dung tin nhắn
  status    String   @default("NEW")     // NEW, CONTACTED, CLOSED
  note      String?  @db.Text            // Ghi chú nội bộ của admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
