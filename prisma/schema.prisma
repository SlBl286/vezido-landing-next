// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  TEACHER
  ASSISTANT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  role          Role      @default(USER)
  hashedPassword      String?
  teacherProfile  Teacher?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Specialty {
  id        String    @id @default(cuid())
  name      String    @unique
  teachers  Teacher[]
  classes   Class[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Teacher {
  id          String      @id @default(cuid())
  userId      String      @unique
  phone       String?
  bio         String?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes     Class[]     @relation("ClassTeachers")
  specialties Specialty[]
  sessions    ClassSession[]
  tasks           Task[]
  taskCompletions TaskCompletion[]
}

model Class {
  id          String         @id @default(cuid())
  name        String         // Tên lớp học
  schedule    String?        // Lịch học (tùy chọn, có thể tự động lấy từ buổi học)
  room        String?        // Phòng học hoặc link online
  courseId    String?
  course      Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  teachers    Teacher[]      @relation("ClassTeachers")
  students    StudentClass[]
  specialties Specialty[]
  sessions    ClassSession[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model StudentClass {
  id                 String       @id @default(cuid())
  studentCode        String?      // Mã học sinh để theo dõi nhiều khóa
  studentName        String
  studentAge         Int?
  parentName         String?
  parentPhone         String?
  classId            String?
  class              Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  isPaid             Boolean      @default(false)
  amountPaid         Float?
  discountCode       String?
  paymentDate        DateTime?
  sepayTransactionId String?      @unique
  paymentMethod      String?      // CASH, TRANSFER, ONLINE
  paymentProof       String?      // Đường dẫn ảnh chụp chuyển khoản
  customDuration     Int?         // Số buổi học tùy chỉnh (nếu học 1 nửa số buổi của khóa...)
  attendance         Attendance[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model ClassSession {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  date        DateTime // Ngày diễn ra buổi học
  startTime   String   // HH:mm (e.g. "08:00")
  endTime     String   // HH:mm (e.g. "10:00")
  room        String?  // Phòng học / Link học trực tuyến
  isMakeup    Boolean  @default(false) // Học bù
  description String?  // Ghi chú (ví dụ: Lý do học bù, nội dung học...)
  status      String   @default("SCHEDULED") // SCHEDULED, CANCELLED, COMPLETED
  attendance  Attendance[]
  artworks    StudentArtwork[]
  taskCompletions TaskCompletion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id             String       @id @default(cuid())
  sessionId      String
  session        ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentClassId String
  studentClass   StudentClass @relation(fields: [studentClassId], references: [id], onDelete: Cascade)
  status         String       // PRESENT, ABSENT, LATE
  notes          String?      // Ghi chú chi tiết (ví dụ: nghỉ có phép, đi muộn 15p...)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([sessionId, studentClassId])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String   @default("Chung")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FaqCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentArtwork {
  id           String        @id @default(cuid())
  studentCode  String        // Mã học sinh để liên kết
  imageUrl     String        // Link tranh vẽ đã tải lên
  title        String?       // Tên tác phẩm
  comment      String?       @db.Text // Nhận xét của giáo viên
  teacherName  String?       // Tên giáo viên nhận xét
  className    String?       // Tên lớp học khi vẽ tranh
  sessionId    String?       // Liên kết với buổi học cụ thể
  session      ClassSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  date         DateTime      @default(now()) // Ngày vẽ tranh
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String                        // Họ tên phụ huynh
  phone     String                        // Số điện thoại liên hệ
  email     String?                       // Email (tùy chọn)
  message   String   @db.Text            // Nội dung tin nhắn
  status    String   @default("NEW")     // NEW, CONTACTED, CLOSED
  note      String?  @db.Text            // Ghi chú nội bộ của admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplyCategory {
  id        String       @id @default(cuid())
  name      String       @unique
  items     SupplyItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model SupplyItem {
  id           String              @id @default(cuid())
  name         String              @unique // Tên họa cụ / đồ dùng
  categoryId   String?
  category     SupplyCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  quantity     Int                 @default(0) // Số lượng hiện tại trong kho
  minQuantity  Int                 @default(5) // Ngưỡng cảnh báo sắp hết
  unit         String              // Đơn vị tính: Cái, Hộp, Chai, Tờ...
  purchaseLink String?             // Link mua sản phẩm
  transactions SupplyTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}


model SupplyTransaction {
  id           String     @id @default(cuid())
  itemId       String
  item         SupplyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type         String     // "IMPORT" (Nhập kho) hoặc "EXPORT" (Xuất dùng/Báo hết)
  quantity     Int        // Số lượng nhập/xuất
  pricePerUnit Float?     // Đơn giá nhập (chỉ có khi IMPORT)
  totalCost    Float?     // Tổng chi phí = quantity * pricePerUnit (chỉ có khi IMPORT)
  purpose      String?    // Lý do xuất dùng hoặc ghi chú nhập kho
  performedBy  String?    // Người thực hiện (tên giáo viên/admin)
  invoices     String[]   // Danh sách file hóa đơn tải lên (PDF/Ảnh)
  date         DateTime   @default(now())
  createdAt    DateTime   @default(now())
}

model Task {
  id                String           @id @default(cuid())
  title             String           // Tên công việc
  description       String?          @db.Text // Mô tả chi tiết
  frequency         String           // SESSION_START, SESSION_END, WEEKLY, MONTHLY, ONCE
  assignedTeacherId String?          // Phân công cụ thể cho giáo viên nào (Null = tất cả)
  assignedTeacher   Teacher?         @relation(fields: [assignedTeacherId], references: [id], onDelete: Cascade)
  completions       TaskCompletion[]
  reward            String?          // Thưởng
  penalty           String?          // Phạt
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model TaskCompletion {
  id          String        @id @default(cuid())
  taskId      String
  task        Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sessionId   String?       // Liên kết với buổi học cụ thể (cho SESSION_START / SESSION_END)
  session     ClassSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  completedAt DateTime      @default(now())
  notes       String?       @db.Text // Ghi chú của giáo viên khi thực hiện
  status      String        @default("COMPLETED") // COMPLETED, SKIPPED
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([taskId, sessionId, teacherId])
}

model ClassCategory {
  id        String   @id @default(cuid())
  name      String   @unique // LỚP MẦM, LỚP CHỒI, LỚP LÁ, DIGITAL ART, etc.
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id              String         @id @default(cuid())
  title           String         @unique // Tên khóa học
  type            String?        // "AGE_BASED" hoặc "SPECIALIZED" (để nullable tránh lỗi dữ liệu cũ)
  audience        String         // Đối tượng học viên
  duration        String         // Thời lượng (ví dụ: "12 buổi / khóa")
  fee             Float          // Học phí (đơn giá)
  feeUnit         String         @default("buổi") // Đơn vị: "buổi", "khóa"
  feeNote         String?        // Ghi chú học phí (ví dụ: "đã bao gồm họa cụ")
  objectives      String[]       // Mục tiêu / Sau khóa học
  content         String[]       // Nội dung lộ trình từng buổi
  benefits        String[]       // Ưu đãi / Khuyến mãi
  isActive        Boolean        @default(true) // Trạng thái hiển thị ngoài landing page
  studyType       String         @default("BY_COURSE") // "BY_MONTH" hoặc "BY_COURSE"
  classes         Class[]
  classCategoryId String?
  classCategory   ClassCategory? @relation(fields: [classCategoryId], references: [id], onDelete: SetNull)
  level           String?        // Ví dụ: Level 1, Level 2
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique // Khóa cấu hình
  value       String   @db.Text // Giá trị cấu hình
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Promotion {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?   @db.Text
  discountType  String    // "PERCENTAGE" hoặc "FIXED_AMOUNT"
  discountValue Float
  minOrderValue Float?
  maxDiscount   Float?
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean   @default(true)
  maxUses       Int?      // Số lần sử dụng tối đa
  usedCount     Int       @default(0) // Số lần đã sử dụng
  isStackable   Boolean   @default(false) // Có được áp dụng chung với nhiều mã khác không
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ExpenseCategory {
  id                 String              @id @default(cuid())
  name               String              @unique
  expenses           Expense[]
  recurringTemplates RecurringTemplate[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Expense {
  id                  String            @id @default(cuid())
  title               String            // Tên khoản chi/thu
  amount              Float             // Số tiền
  type                String            @default("EXPENSE") // "EXPENSE" hoặc "REVENUE"
  categoryId          String?
  category            ExpenseCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date                DateTime          @default(now()) // Ngày giao dịch
  description         String?           @db.Text // Ghi chú chi tiết
  invoices            String[]          // Danh sách đường dẫn ảnh hóa đơn
  supplyTransactionId String?           // Liên kết giao dịch kho (nếu có)
  recurringHistory    RecurringHistory?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model RecurringTemplate {
  id          String             @id @default(cuid())
  title       String             // Tên khoản thu/chi cố định
  amount      Float              // Số tiền
  type        String             @default("EXPENSE") // "EXPENSE" hoặc "REVENUE"
  dayOfMonth  Int                // Ngày tạo tự động hàng tháng (1-31)
  categoryId  String?
  category    ExpenseCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String?            @db.Text
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  history     RecurringHistory[]
}

model RecurringHistory {
  id          String            @id @default(cuid())
  templateId  String
  template    RecurringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  month       Int               // Tháng (1-12)
  year        Int               // Năm
  generatedAt DateTime          @default(now())
  expenseId   String?           @unique
  expense     Expense?          @relation(fields: [expenseId], references: [id], onDelete: SetNull)
}

